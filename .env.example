# ============================================================
#  TakipçiPro v2 — Sunucu Yapılandırması
#  Bu dosyayı kopyala: cp .env.example .env
#  Sonra .env dosyasını kendi bilgillerinle doldur
# ============================================================

# SosyalBizde (veya başka SMM panel) API Bilgileri
SMMPANEL_URL=https://sosyalbizde.com/api/v2
SMMPANEL_KEY=BURAYA_API_ANAHTARINI_YAZ

# Güvenlik: Hangi siteden istek kabul edilsin?
# Netlify URL'in (örn: https://takipcipro.netlify.app)
# Geliştirme için: * (herkese açık)
FRONTEND_URL=https://takipcipro.netlify.app

# Sunucu Portu (ngrok bu porta tünel açacak)
PORT=3000

# Dahili API Güvenlik Anahtarı
# Netlify sitesinde de aynı değer olmalı (bota karşı)
# Rastgele uzun bir şifre yaz
INTERNAL_API_KEY=gizli-rastgele-anahtar-buraya-yaz

# MongoDB Bağlantısı
# Yerel: mongodb://localhost:27017/takipcipro
# Atlas : mongodb+srv://kullanici:sifre@cluster.mongodb.net/takipcipro
MONGO_URI=mongodb://localhost:27017/takipcipro

# Servis ID'leri (artık MongoDB'den yönetiliyor — bu alanlar gerekmez)
# Panele gir → Servisler → ID sütununu kopyala
SERVICE_100=101
SERVICE_250=102
SERVICE_500=103
SERVICE_1000=104
SERVICE_2500=105
SERVICE_5000=106
